# ============================================================================
# Personal Finance — environment variables
# Copy the relevant sections into real env files (which are gitignored):
#   - Server vars  -> server/.env   (Express)
#   - Client vars  -> client/.env   (Vite; only VITE_* are exposed to the browser)
# Never commit real secrets. Never put service-role / JWT secrets in client/.env.
# ============================================================================

# ---- Server (Express) --------------------------------------------------------

# AI transaction categorizer
ANTHROPIC_API_KEY=your_key_here

PORT=3001

# Legacy local SQLite path — obsolete after the Postgres migration (Phase 1).
DATABASE_PATH=./data/finance.db

# Supabase Postgres connection string.
# Supabase dashboard -> Project Settings -> Database -> Connection string -> URI
# (use the "Session"/pooler URI; replace [YOUR-PASSWORD]).
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase dashboard -> Project Settings -> API
SUPABASE_URL=https://[PROJECT-REF].supabase.co

# service_role secret key (Project Settings -> API -> Project API keys -> service_role).
# SERVER ONLY. Grants admin access (used for inviteUserByEmail + signed URLs).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# JWT secret (Project Settings -> API -> JWT Settings -> JWT Secret).
# Used by the server to verify the access token on each request.
SUPABASE_JWT_SECRET=your_jwt_secret

# ---- Client (Vite) — put these in client/.env --------------------------------

VITE_SUPABASE_URL=https://[PROJECT-REF].supabase.co

# anon public key (Project Settings -> API -> Project API keys -> anon public).
# Safe to expose to the browser.
VITE_SUPABASE_ANON_KEY=your_anon_key
